<script id="sl-chart-trend"  type="application/json">{{{chartTrend}}}</script>
<script id="sl-peer-chart"   type="application/json">{{{peerChart}}}</script>
<script>window.__slSources = {{{orgSourcesJson}}};</script>

<div id="org-topbar">
  <div class="org-topbar-left">
    <a href="/sector/{{org.sic_code}}" class="sic-badge">{{org.sic_code}}</a>
    <span style="color:var(--text-3);font-size:13px;">›</span>
    <div class="org-topbar-name">{{org.name}}</div>
    {{#if org.ticker}}<span class="ticker-badge">{{org.ticker}}</span>{{/if}}
    <span class="type-badge">{{org.type}}</span>
  </div>
  <div style="display:flex;gap:10px;align-items:center;">
    <button class="btn btn-outline btn-sm" @click="modal='sources'">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="margin-right:2px;">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      Sources
    </button>
    <a href="/sector/{{org.sic_code}}" class="btn btn-outline btn-sm">← Back to Sector</a>
  </div>
</div>

<div class="page-body">
  <div class="breadcrumb">
    <a href="/">Home</a> ›
    <a href="/sector/{{org.sic_code}}">SIC {{org.sic_code}} — {{sector.name}}</a> ›
    <span>{{org.name}}</span>
  </div>

  {{!-- Manual entry notice --}}
  {{#if isManual}}
  <div style="padding:12px 16px;background:#2563eb12;border:1px solid #2563eb30;border-radius:var(--r-lg);
              margin-bottom:20px;font-size:13px;color:#2563eb;display:flex;align-items:center;gap:10px;">
    <span>ℹ</span>
    <span>This is a manually entered comparison entry.
      <a href="/sector/{{org.sic_code}}" style="color:#2563eb;font-weight:500;">
        Return to sector ↗
      </a>
      to run a new comparison or update values.
    </span>
  </div>
  {{/if}}

  {{!-- ORG HEADER --}}
  <div class="org-header-card">
    <div>
      <div class="org-name">{{org.name}}</div>
      <div class="org-meta-row">
        {{#if org.ticker}}<span class="ticker-badge" style="font-size:12px;">{{org.country}}:{{org.ticker}}</span>{{/if}}
        <span class="type-badge" style="font-size:11px;">{{org.type}}</span>
        {{#if org.city}}<span style="font-size:12px;color:var(--text-3);">{{org.city}}{{#if org.state}}, {{org.state}}{{/if}}</span>{{/if}}
        {{#if org.employee_count}}<span style="font-size:12px;color:var(--text-3);">~{{org.employee_count}} employees</span>{{/if}}
      </div>
      {{#if org.description}}<div class="org-desc">{{org.description}}</div>{{/if}}
      {{#if fin}}
      <div class="org-stat-pills" style="margin-top:14px;">
        <div class="stat-pill">Revenue <strong>{{fin_fmt.revenue}}</strong></div>
        <div class="stat-pill">Net Income <strong>{{fin_fmt.net_income}}</strong></div>
        <div class="stat-pill">Total Assets <strong>{{fin_fmt.total_assets}}</strong></div>
        <div class="stat-pill">FY <strong>2023</strong></div>
      </div>
      {{/if}}
    </div>
    {{#if org.credit_rating}}
    <div class="credit-box">
      <div class="credit-rating">{{org.credit_rating}}</div>
      <div class="credit-label">Credit Rating</div>
      <div class="credit-agency">{{org.credit_agency}} · {{org.credit_outlook}}</div>
    </div>
    {{/if}}
  </div>

  {{!-- KPI TILES --}}
  <div class="section-head"><h2>Key Financial Metrics</h2><span>FY 2023 · vs Sector Median</span></div>
  <div class="kpi-grid">
    {{#each kpis}}
    <div class="kpi-card {{accentClass}}">
      <div class="kpi-label">{{label}}</div>
      <div class="kpi-value">{{value}}</div>
      <div class="kpi-vs">vs sector <strong>{{sectorMedian}}</strong></div>
      <div class="kpi-delta {{trend}}">
        {{#if (eq trend 'pos')}}↑ Above Median{{else}}{{#if (eq trend 'neg')}}↓ Below Median{{else}}— At Median{{/if}}{{/if}}
      </div>
    </div>
    {{/each}}
  </div>

  {{!-- TREND CHARTS --}}
  <div class="section-head"><h2>Financial Trends</h2><span>5-Year History</span></div>
  <div class="charts-2col">
    <div class="chart-panel">
      <div class="panel-title">Revenue &amp; Net Income <span>$B</span></div>
      <canvas id="trendChart"></canvas>
    </div>
    <div class="chart-panel">
      <div class="panel-title">Margin &amp; Returns <span>%</span></div>
      <canvas id="marginTrendChart"></canvas>
    </div>
  </div>

  {{!-- PEER COMPARISON --}}
  <div class="section-head"><h2>Peer Comparison</h2><span>SIC {{org.sic_code}} · FY 2023</span></div>
  <div class="chart-panel" style="margin-bottom:16px;">
    <div class="panel-title">Revenue vs Peers <span>$B</span></div>
    <canvas id="peerChart" style="max-height:180px;"></canvas>
  </div>
  <div class="peer-panel" style="margin-bottom:28px;">
    <div class="peer-panel-header"><div class="peer-panel-title">Peer Benchmark Table</div></div>
    <table>
      <thead>
        <tr><th>Organization</th><th>Revenue</th><th>Net Income</th><th>Net Margin</th></tr>
      </thead>
      <tbody>
        <tr style="background:var(--bg-alt);">
          <td><strong>{{org.name}}</strong> <span class="you-marker">YOU</span></td>
          <td>{{fin_fmt.revenue}}</td>
          <td>{{fin_fmt.net_income}}</td>
          <td>{{fin_fmt.net_margin}}</td>
        </tr>
        {{#each peers}}
        <tr>
          <td><a class="org-link" href="/org/{{id}}">{{name}}</a></td>
          <td>{{revenueFmt}}</td>
          <td>{{netIncomeFmt}}</td>
          <td>{{netMarginFmt}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  {{!-- BANKER PANEL --}}
  <div class="banker-panel">
    <div class="banker-panel-title">Banker's Assessment</div>
    <div class="banker-panel-sub">Pre-assessment based on reported financials. Not a credit decision.</div>
    <div class="banker-grid">
      <div class="banker-block">
        <div class="banker-block-title">Key Risk Indicators</div>
        {{#each kpis}}
        <div class="risk-item">
          <div class="risk-dot {{#if (eq trend 'pos')}}dot-green{{else}}{{#if (eq trend 'neg')}}dot-warn{{else}}dot-neu{{/if}}{{/if}}"></div>
          <span>{{label}}: <strong>{{value}}</strong> (sector median: {{sectorMedian}})</span>
        </div>
        {{/each}}
      </div>
      <div class="banker-block">
        <div class="banker-block-title" style="display:flex;align-items:center;justify-content:space-between;">
          <span>Indicative Loan Parameters</span>
          {{#if loanParams.strategyActive}}
          <a href="/account/strategy" style="font-size:10px;padding:2px 7px;background:#eff6ff;color:#1d4ed8;border-radius:3px;text-decoration:none;">Custom strategy ✓</a>
          {{/if}}
        </div>
        {{#if loanParams.hasData}}
        {{#if loanParams.leverageWarning}}
        <div style="padding:8px 10px;background:#fef2f2;border-radius:var(--r-md);font-size:11px;color:#991b1b;margin-bottom:10px;line-height:1.5;">
          {{loanParams.leverageWarning}}
        </div>
        {{/if}}
        <div class="rec-box">
          <div class="rec-box-label">Max Loan (Indicative)</div>
          <div class="rec-box-val">{{loanParams.maxLoanFmt}}</div>
          <div class="rec-box-note">4× EBITDA senior limit · Review DSCR and collateral in diligence</div>
        </div>
        <div style="margin-top:12px;">
          <div class="loan-row"><span>Rate Tier</span><span class="loan-val">{{loanParams.rateLabel}}</span></div>
          <div class="loan-row"><span>Suggested Term</span><span class="loan-val">{{loanParams.term}}</span></div>
          <div class="loan-row"><span>Amortization</span><span class="loan-val">{{loanParams.amort}}</span></div>
          <div class="loan-row"><span>Covenant Package</span><span class="loan-val">{{loanParams.covenant}}</span></div>
          <div class="loan-row" style="margin-top:4px;border-top:1px solid var(--border);padding-top:8px;">
            <span>DSCR</span>
            <span class="loan-val" style="color:{{#if loanParams.dscr}}{{#if (gte loanParams.dscr 1.5)}}var(--green){{else}}var(--warn){{/if}}{{else}}var(--text-3){{/if}};">
              {{#if loanParams.dscr}}{{loanParams.dscr}}×{{else}}—{{/if}}
            </span>
          </div>
          <div class="loan-row">
            <span>Leverage</span>
            <span class="loan-val">{{#if loanParams.leverage}}{{loanParams.leverage}}× EBITDA{{else}}—{{/if}}</span>
          </div>
        </div>
        <button @click="modal='loan-analysis'"
                class="btn btn-outline btn-sm"
                style="margin-top:12px;width:100%;font-size:12px;">
          View detailed analysis →
        </button>
        {{else}}
        <div style="padding:16px;text-align:center;color:var(--text-3);font-size:12px;">
          <div style="margin-bottom:6px;">No financial data available</div>
          <div>Loan parameters require revenue, net income, or asset data</div>
        </div>
        {{/if}}
      </div>
      <div class="banker-block">
        <div class="banker-block-title">Analyst Notes</div>
        <p style="font-size:13px;color:var(--text-2);line-height:1.65;">
          Review this organization's most recent audited financials, credit history, and DSCR before making any credit determination. Compare against SIC {{org.sic_code}} sector benchmarks for context. This assessment is based on seed/public data and is indicative only.
        </p>
      </div>
    </div>
  </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const t   = JSON.parse(document.getElementById('sl-chart-trend').textContent);
  const p   = JSON.parse(document.getElementById('sl-peer-chart').textContent);
  const dark   = document.documentElement.getAttribute('data-theme') === 'dark';
  const grid   = dark ? '#252525' : '#f0f0f0';
  const tick   = dark ? '#666'    : '#8a8a8a';
  const legend = dark ? '#999'    : '#4a4a4a';

  if (document.getElementById('trendChart') && t.years && t.years.length) {
    new Chart(document.getElementById('trendChart'), {
      data: {
        labels: t.years,
        datasets: [
          { type: 'bar',  label: 'Revenue ($B)',    data: t.revenues,  backgroundColor: '#2563eb', borderRadius: 3, yAxisID: 'y' },
          { type: 'line', label: 'Net Income ($B)', data: t.netIncomes, borderColor: '#16a34a', backgroundColor: 'transparent', tension: .35, pointRadius: 4, borderWidth: 2, fill: false, yAxisID: 'y2' },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: true,
        plugins: { legend: { labels: { font: { family: 'DM Sans', size: 11 }, color: legend } } },
        scales: {
          y:  { type: 'linear', position: 'left',  ticks: { font: { family: 'DM Sans', size: 10 }, color: tick, callback: v => '$' + v + 'B' }, grid: { color: grid } },
          y2: { type: 'linear', position: 'right', ticks: { font: { family: 'DM Sans', size: 10 }, color: tick, callback: v => '$' + v + 'B' }, grid: { display: false } },
          x:  { ticks: { font: { family: 'DM Sans', size: 10 }, color: tick }, grid: { display: false } },
        },
      },
    });

    new Chart(document.getElementById('marginTrendChart'), {
      type: 'line',
      data: {
        labels: t.years,
        datasets: [
          { label: 'Net Margin %',      data: t.netMargins,       borderColor: '#2563eb', backgroundColor: '#2563eb22', tension: .35, pointRadius: 4, borderWidth: 2, fill: true },
          { label: 'ROE %',             data: t.roes,             borderColor: '#16a34a', backgroundColor: 'transparent', tension: .35, pointRadius: 4, borderWidth: 2, fill: false },
          { label: 'Efficiency Ratio %',data: t.efficiencyRatios, borderColor: '#d97706', backgroundColor: 'transparent', tension: .35, pointRadius: 4, borderWidth: 2, fill: false, borderDash: [4, 3] },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: true,
        plugins: { legend: { labels: { font: { family: 'DM Sans', size: 11 }, color: legend } } },
        scales: {
          x: { ticks: { font: { family: 'DM Sans', size: 10 }, color: tick }, grid: { display: false } },
          y: { ticks: { font: { family: 'DM Sans', size: 10 }, color: tick, callback: v => v + '%' }, grid: { color: grid } },
        },
      },
    });
  }

  if (document.getElementById('peerChart') && p.labels && p.labels.length) {
    const peerColors = p.labels.map((_, i) => i === 0 ? '#2563eb' : '#2563eb55');
    new Chart(document.getElementById('peerChart'), {
      type: 'bar',
      data: {
        labels: p.labels,
        datasets: [
          { label: 'Revenue ($B)',    data: p.revenues,  backgroundColor: peerColors, borderRadius: 3 },
          { label: 'Net Income ($B)', data: p.netIncomes, backgroundColor: p.labels.map((_, i) => i === 0 ? '#16a34a' : '#16a34a55'), borderRadius: 3 },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: true,
        plugins: { legend: { labels: { font: { family: 'DM Sans', size: 11 }, color: legend } } },
        scales: {
          x: { ticks: { font: { family: 'DM Sans', size: 10 }, color: tick }, grid: { display: false } },
          y: { ticks: { font: { family: 'DM Sans', size: 10 }, color: tick, callback: v => '$' + v + 'B' }, grid: { color: grid } },
        },
      },
    });
  }
});
</script>
