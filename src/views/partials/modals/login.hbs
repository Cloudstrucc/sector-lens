{{!-- LOGIN --}}
<div class="modal-overlay" :class="{open: modal==='login'}" @click.self="modal=null">
  <div class="modal" @click.stop>
    <div class="modal-header">
      <div class="modal-title">Log In</div>
      <button class="modal-close" @click="modal=null">×</button>
    </div>
    <form action="/auth/login" method="POST">
      <div class="modal-body">
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" placeholder="you@institution.com" required>
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" name="password" placeholder="••••••••" required>
        </div>
      </div>
      <div class="modal-footer" style="flex-direction:column;gap:8px;">
        <button type="submit" class="btn btn-primary" style="width:100%;">Log In</button>
        <button type="button" class="btn btn-outline" style="width:100%;font-size:12px;" @click="modal='register'">Don't have an account? Register</button>
      </div>
    </form>
  </div>
</div>
