<div class="page-body">
  <div class="breadcrumb"><a href="/">Home</a> › <span>My Account</span></div>
  <div style="max-width:560px;">
    <h1 style="font-family:'Cormorant Garant',serif;font-size:28px;font-weight:600;margin-bottom:24px;">My Account</h1>
    {{#if user}}
    <div class="org-header-card" style="margin-bottom:24px;">
      <div>
        <div class="org-name" style="font-size:20px;">{{user.first_name}} {{user.last_name}}</div>
        <div style="font-size:13px;color:var(--text-3);margin-top:4px;">{{user.email}}</div>
        <div style="margin-top:12px;">
          <span class="badge-type badge-pub" style="font-size:12px;padding:3px 10px;">
            {{user.subscription_tier}} plan
          </span>
        </div>
      </div>
    </div>
    <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;">
      <a href="/account/strategy" class="btn btn-outline" style="display:flex;align-items:center;gap:8px;justify-content:space-between;">
        <span>⚙ Lending Strategy</span>
        <span style="font-size:12px;color:var(--text-3);">Configure loan analysis parameters →</span>
      </a>
    </div>
    <a href="/auth/logout" class="btn btn-outline">Log Out</a>
    {{/if}}
  </div>
</div>
