{
  "name": "sectorlens",
  "version": "1.0.0",
  "description": "Commercial banking intelligence platform for SIC-based sector analysis",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "node -e \"require('./src/config/database').runMigrations()\"",
    "db:seed": "node -e \"require('./src/config/database').runSeeds().then(()=>process.exit(0)).catch(e=>{console.error(e.message);process.exit(1)})\"",
    "db:migrate": "node -e \"require('./src/config/database').runMigrations().then(()=>process.exit(0)).catch(e=>{console.error(e.message);process.exit(1)})\"",
    "db:reset": "node -e \"require('./src/config/database').resetDb().then(()=>process.exit(0)).catch(e=>{console.error(e.message);process.exit(1)})\""
  },
  "dependencies": {
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.6.0",
    "compression": "^1.7.4",
    "connect-sqlite3": "^0.9.16",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-handlebars": "^7.1.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "i18next": "^23.8.2",
    "i18next-fs-backend": "^2.3.2",
    "i18next-http-middleware": "^3.5.0",
    "knex": "^3.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.9",
    "sqlite3": "^6.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  },
  "nodemonConfig": {
    "ignore": [
      "data/*",
      "*.db"
    ],
    "ext": "js,hbs,json,css"
  }
}