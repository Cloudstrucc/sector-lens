# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Session ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# ─── Database ─────────────────────────────────────────────
# Path to the SQLite database file
# On Azure App Service use: /home/data/sectorlens.db
DB_PATH=./data/sectorlens.db
DB_DIR=./data

# ─── External APIs ────────────────────────────────────────
# Financial Modeling Prep (free tier: 250 req/day)
# https://financialmodelingprep.com/developer/docs/
FMP_API_KEY=

# UK Companies House (free key — developer.company-information.service.gov.uk)
COMPANIES_HOUSE_API_KEY=

# ─── Data Ingestion ────────────────────────────────────────
# Set to false to disable nightly scheduled ingestion
INGEST_ENABLED=true

# Cron schedule for nightly ingestion (default: 2am UTC daily)
INGEST_CRON_SCHEDULE=0 2 * * *

# Comma-separated country codes to ingest (US,CA,GB,EU or ALL)
INGEST_COUNTRIES=US,CA

# User-Agent sent with all external API requests (include your contact email)
INGEST_USER_AGENT=SectorLens/1.0 (your-email@domain.com)

# ─── Email (optional for dev, required for invites/trials) ─
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@sectorlens.com

# ─── Azure (production only) ──────────────────────────────
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=sectorlens-backups
