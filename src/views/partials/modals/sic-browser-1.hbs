{{!-- SIC Browser modal — loads SICs from /api/sics on open --}}
<div class="modal-overlay"
     :class="{open: modal==='sic-browser'}"
     @click.self="modal=null"
     x-data="sicBrowser()"
     @open-sic-browser.window="openBrowser()">

  <div class="modal sic-browser-modal" @click.stop>

    <div class="modal-header" style="flex-shrink:0;">
      <div>
        <div class="modal-title">Browse SIC Codes</div>
        <div style="font-size:12px;color:var(--text-3);margin-top:2px;">
          <span x-text="filtered.length"></span> of <span x-text="sics.length"></span> sectors
        </div>
      </div>
      <button class="modal-close" @click="modal=null">×</button>
    </div>

    {{!-- Search --}}
    <div style="padding:12px 24px;border-bottom:1px solid var(--border);flex-shrink:0;">
      <input type="text"
             x-model="query"
             @input="filterSics()"
             placeholder="Filter by code or name… e.g. 6022 or bank"
             style="width:100%;padding:9px 12px;border:1px solid var(--border);border-radius:var(--r);
                    font-family:'DM Sans',sans-serif;font-size:13.5px;outline:none;
                    background:var(--bg);color:var(--text);box-sizing:border-box;"
             x-ref="searchInput">
    </div>

    {{!-- Loading --}}
    <div x-show="loading"
         style="flex:1;display:flex;align-items:center;justify-content:center;padding:40px;color:var(--text-3);font-size:13px;">
      Loading SIC codes…
    </div>

    {{!-- DESKTOP table (hidden on mobile via CSS) --}}
    <div x-show="!loading" class="sic-table-wrap" style="flex:1;overflow-y:auto;">
      <table style="width:100%;border-collapse:collapse;table-layout:fixed;">
        <colgroup>
          <col style="width:8%;">
          <col style="width:22%;">
          <col style="width:9%;">
          <col style="width:20%;">
          <col style="width:23%;">
          <col style="width:18%;">
        </colgroup>
        <thead style="position:sticky;top:0;z-index:2;">
          <tr>
            <th class="sic-th sic-th-sort" style="padding-left:24px;" @click="sortBy('sic_code')">
              SIC <span x-text="sortIcon('sic_code')" class="sort-icon"></span>
            </th>
            <th class="sic-th sic-th-sort" @click="sortBy('name')">
              Sector Name <span x-text="sortIcon('name')" class="sort-icon"></span>
            </th>
            <th class="sic-th sic-th-sort" style="text-align:right;" @click="sortBy('entity_count')">
              Entities <span x-text="sortIcon('entity_count')" class="sort-icon"></span>
            </th>
            <th class="sic-th">Country</th>
            <th class="sic-th">Sources</th>
            <th class="sic-th"></th>
          </tr>
        </thead>
        <tbody>
          <template x-for="sic in filtered" :key="sic.sic_code + '-desk'">
            <tr style="border-bottom:1px solid var(--border);"
                @mouseenter="$el.style.background='var(--bg-alt)'"
                @mouseleave="$el.style.background=''">
              <td style="padding:10px 12px 10px 24px;">
                <span style="font-family:'Cormorant Garant',serif;font-size:17px;font-weight:600;"
                      x-text="sic.sic_code"></span>
              </td>
              <td style="padding:10px 8px;font-size:13px;color:var(--text);" x-text="sic.name"></td>
              <td style="padding:10px 12px;text-align:right;font-size:12px;color:var(--text-3);"
                  x-text="sic.entity_count > 0 ? sic.entity_count.toLocaleString() + ' orgs' : '—'"></td>

              {{!-- Country pills — max 5 visible, +N expands --}}
              <td style="padding:10px 8px;" x-data="{expanded: false}">
                <template x-if="sic.countries && sic.countries.length > 0">
                  <div style="display:flex;gap:3px;flex-wrap:wrap;align-items:center;">
                    <template x-for="(c, i) in (expanded ? sic.countries : sic.countries.slice(0,3))" :key="c">
                      <span x-text="c"
                            :style="countryPillStyle(c)"
                            style="font-size:10px;padding:2px 6px;border-radius:3px;white-space:nowrap;"></span>
                    </template>
                    <template x-if="!expanded && sic.countries.length > 3">
                      <span @click.stop="expanded=true"
                            x-text="'+' + (sic.countries.length - 3)"
                            style="font-size:10px;padding:2px 6px;border-radius:3px;background:var(--bg-alt);color:var(--text-2);border:0.5px solid var(--border);cursor:pointer;white-space:nowrap;"></span>
                    </template>
                    <template x-if="expanded && sic.countries.length > 3">
                      <span @click.stop="expanded=false"
                            style="font-size:10px;padding:2px 6px;border-radius:3px;background:var(--bg-alt);color:var(--text-2);border:0.5px solid var(--border);cursor:pointer;white-space:nowrap;">↑</span>
                    </template>
                  </div>
                </template>
                <template x-if="!sic.countries || sic.countries.length === 0">
                  <span style="font-size:12px;color:var(--text-3);">—</span>
                </template>
              </td>

              {{!-- Source pills — max 3 visible, +N expands --}}
              <td style="padding:10px 8px;" x-data="{sexp: false}">
                <template x-if="sic.sources && sic.sources.length > 0">
                  <div style="display:flex;gap:3px;flex-wrap:wrap;align-items:center;">
                    <template x-for="src in (sexp ? sic.sources : sic.sources.slice(0,3))" :key="src">
                      <span x-text="src"
                            style="font-size:10px;padding:2px 6px;border-radius:3px;background:var(--bg-alt);color:var(--text-2);border:0.5px solid var(--border);white-space:nowrap;"></span>
                    </template>
                    <template x-if="!sexp && sic.sources.length > 3">
                      <span @click.stop="sexp=true"
                            x-text="'+' + (sic.sources.length - 3)"
                            style="font-size:10px;padding:2px 6px;border-radius:3px;background:var(--bg-alt);color:var(--text-2);border:0.5px solid var(--border);cursor:pointer;white-space:nowrap;"></span>
                    </template>
                    <template x-if="sexp && sic.sources.length > 3">
                      <span @click.stop="sexp=false"
                            style="font-size:10px;padding:2px 6px;border-radius:3px;background:var(--bg-alt);color:var(--text-2);border:0.5px solid var(--border);cursor:pointer;white-space:nowrap;">↑</span>
                    </template>
                  </div>
                </template>
                <template x-if="!sic.sources || sic.sources.length === 0">
                  <span style="font-size:12px;color:var(--text-3);">—</span>
                </template>
              </td>

              <td style="padding:8px 16px 8px 8px;text-align:right;">
                <a :href="'/sector/' + sic.sic_code"
                   @click="modal=null"
                   class="btn btn-outline btn-sm"
                   style="white-space:nowrap;text-decoration:none;font-size:12px;">
                  Search →
                </a>
              </td>
            </tr>
          </template>
          <template x-if="!loading && filtered.length === 0">
            <tr>
              <td colspan="6" style="padding:32px;text-align:center;font-size:13px;color:var(--text-3);">
                No SIC codes match "<span x-text="query"></span>"
              </td>
            </tr>
          </template>
        </tbody>
      </table>
    </div>

    {{!-- MOBILE card list (hidden on desktop via CSS) --}}
    <div x-show="!loading" class="sic-card-list" style="flex:1;overflow-y:auto;">
      <template x-for="sic in filtered" :key="sic.sic_code + '-mob'">
        <div style="border-bottom:1px solid var(--border);padding:12px 16px;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px;">
            <div>
              <span style="font-family:'Cormorant Garant',serif;font-size:18px;font-weight:600;color:var(--text);"
                    x-text="sic.sic_code"></span>
              <span style="font-size:12px;color:var(--text-3);margin-left:8px;"
                    x-text="sic.entity_count > 0 ? sic.entity_count.toLocaleString() + ' orgs' : '—'"></span>
            </div>
            <a :href="'/sector/' + sic.sic_code"
               @click="modal=null"
               class="btn btn-outline btn-sm"
               style="white-space:nowrap;text-decoration:none;font-size:11px;padding:4px 10px;flex-shrink:0;">
              Search →
            </a>
          </div>
          <div style="font-size:13px;color:var(--text);margin-bottom:6px;" x-text="sic.name"></div>
          <div x-data="{mexp: false}" style="display:flex;gap:3px;flex-wrap:wrap;align-items:center;">
            {{!-- Country pills — max 5 visible on mobile too --}}
            <template x-if="sic.countries && sic.countries.length > 0">
              <template x-for="(c, i) in (mexp ? sic.countries : sic.countries.slice(0,3))" :key="'m-c-' + c">
                <span x-text="c"
                      :style="countryPillStyle(c)"
                      style="font-size:10px;padding:2px 6px;border-radius:3px;white-space:nowrap;"></span>
              </template>
            </template>
            <template x-if="sic.countries && !mexp && sic.countries.length > 3">
              <span @click.stop="mexp=true"
                    x-text="'+' + (sic.countries.length - 3)"
                    style="font-size:10px;padding:2px 6px;border-radius:3px;background:var(--bg-alt);color:var(--text-2);border:0.5px solid var(--border);cursor:pointer;white-space:nowrap;"></span>
            </template>
            {{!-- Source pills — max 3 visible on mobile --}}
            <template x-if="sic.sources && sic.sources.length > 0">
              <template x-for="src in (mexp ? sic.sources : sic.sources.slice(0,3))" :key="'m-s-' + src">
                <span x-text="src"
                      style="font-size:10px;padding:2px 6px;border-radius:3px;background:var(--bg-alt);color:var(--text-2);border:0.5px solid var(--border);white-space:nowrap;"></span>
              </template>
            </template>
            <template x-if="sic.sources && !mexp && sic.sources.length > 3">
              <span @click.stop="mexp=true"
                    x-text="'+' + (sic.sources.length - 3)"
                    style="font-size:10px;padding:2px 6px;border-radius:3px;background:var(--bg-alt);color:var(--text-2);border:0.5px solid var(--border);cursor:pointer;white-space:nowrap;"></span>
            </template>
            <template x-if="(!sic.countries || sic.countries.length === 0) && (!sic.sources || sic.sources.length === 0)">
              <span style="font-size:11px;color:var(--text-3);">No data yet</span>
            </template>
          </div>
        </div>
      </template>
      <template x-if="!loading && filtered.length === 0">
        <div style="padding:32px;text-align:center;font-size:13px;color:var(--text-3);">
          No SIC codes match "<span x-text="query"></span>"
        </div>
      </template>
    </div>

    <div class="modal-footer" style="flex-shrink:0;border-top:1px solid var(--border);">
      <button class="btn btn-outline btn-sm" @click="modal=null">Close</button>
    </div>
  </div>
</div>

<script>
function sicBrowser() {
  return {
    sics:     [],
    filtered: [],
    query:    '',
    loading:  false,
    sortCol:  'sic_code',
    sortDir:  'asc',

    async openBrowser() {
      if (this.sics.length === 0) await this.loadSics();
      this.$nextTick(() => this.$refs.searchInput && this.$refs.searchInput.focus());
    },

    async loadSics() {
      this.loading = true;
      try {
        const resp = await fetch('/api/sics');
        const data = await resp.json();
        this.sics     = data;
        this.filtered = this.sortList(data);
      } catch (e) {
        console.warn('Could not load SIC codes', e);
      }
      this.loading = false;
    },

    filterSics() {
      const q = this.query.toLowerCase().trim();
      const base = !q ? this.sics : this.sics.filter(s =>
        s.sic_code.includes(q) ||
        s.name.toLowerCase().includes(q) ||
        (s.name_fr && s.name_fr.toLowerCase().includes(q)) ||
        (s.countries && s.countries.some(c => c.toLowerCase().includes(q))) ||
        (s.sources   && s.sources.some(src => src.toLowerCase().includes(q)))
      );
      this.filtered = this.sortList(base);
    },

    sortBy(col) {
      if (this.sortCol === col) {
        this.sortDir = this.sortDir === 'asc' ? 'desc' : 'asc';
      } else {
        this.sortCol = col;
        this.sortDir = col === 'entity_count' ? 'desc' : 'asc';
      }
      this.filtered = this.sortList(this.filtered);
    },

    sortList(list) {
      const dir = this.sortDir === 'asc' ? 1 : -1;
      return [...list].sort((a, b) => {
        if (this.sortCol === 'entity_count') return dir * ((a.entity_count || 0) - (b.entity_count || 0));
        if (this.sortCol === 'name')         return dir * a.name.localeCompare(b.name);
        return dir * a.sic_code.localeCompare(b.sic_code);
      });
    },

    sortIcon(col) {
      if (this.sortCol !== col) return '↕';
      return this.sortDir === 'asc' ? '↑' : '↓';
    },

    countryPillStyle(code) {
      const styles = {
        'US': 'background:#E6F1FB;color:#0C447C;',
        'CA': 'background:#EAF3DE;color:#27500A;',
        'EU': 'background:#EEEDFE;color:#3C3489;',
        'GB': 'background:#EEEDFE;color:#3C3489;',
        'AU': 'background:#FAEEDA;color:#633806;',
      };
      return styles[code] || 'background:#F1EFE8;color:#444441;';
    },
  };
}
</script>
