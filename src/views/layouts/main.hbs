<!DOCTYPE html>
<html lang="{{locale}}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{title}}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,300;0,400;0,600;1,300&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
<!-- Prevent dark mode flash -->
<script>
  (function(){
    const t = localStorage.getItem('sl-theme') || 'light';
    document.documentElement.setAttribute('data-theme', t);
  })();
</script>
<link rel="stylesheet" href="/css/main.css">
</head>
<body x-data="sectorApp()" x-init="init()" :data-theme="theme">

{{> nav}}

{{{body}}}

{{> modals/login}}
{{> modals/register}}
{{> modals/trial}}
{{> modals/redeem}}
{{> modals/compare}}
{{> modals/sources}}
{{> modals/sic-browser}}

{{#if flash}}
<div class="flash-banner flash-{{flash.type}}" x-data="{show:true}" x-show="show" x-transition>
  <span>{{flash.text}}</span>
  <button @click="show=false" aria-label="close">×</button>
</div>
{{/if}}

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.5/dist/cdn.min.js"></script>
<script src="/js/app.js"></script>
<script>
  // Pass server locale to client
  window.SL_LOCALE = '{{locale}}';
  window.SL_USER   = {{#if user}}{id:{{user.id}},tier:'{{user.subscription_tier}}'}{{else}}null{{/if}};
</script>
</body>
</html>
