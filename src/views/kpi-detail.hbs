<script id="sl-compare-metrics" type="application/json">{{{compareMetrics}}}</script>
<script id="sl-rank-chart" type="application/json">{{{chartEntities}}}</script>

<div id="metric-bar">
  <div class="metric-bar-left">
    <a href="/sector/{{sic}}" class="sic-badge">{{sic}}</a>
    <span style="color:var(--text-3);font-size:13px;">›</span>
    <div class="metric-name">{{metricLabel}}</div>
    <span class="metric-category">
      {{#if isPercent}}Ratio / %{{else}}{{#if isRatio}}Leverage{{else}}Absolute ($){{/if}}{{/if}}
    </span>
  </div>
  <div style="font-size:12px;color:var(--text-3);">{{sector.entity_count}} entities · FY 2023</div>
</div>

<div class="page-body">
  <div class="breadcrumb">
    <a href="/">Home</a> ›
    <a href="/sector/{{sic}}">SIC {{sic}} — {{sector.name}}</a> ›
    <span>{{metricLabel}}</span>
  </div>

  {{!-- STAT CARDS --}}
  <div class="stat-grid">
    {{#if bench}}
    <div class="stat-card">
      <div class="stat-label">Sector Median</div>
      <div class="stat-value">
        {{#if isPercent}}{{bench.median}}%{{else}}{{#if isRatio}}{{bench.median}}×{{else}}${{bench.median}}{{/if}}{{/if}}
      </div>
      <div class="stat-sub">{{bench.entity_count}} entities · FY 2023</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">75th Percentile</div>
      <div class="stat-value">
        {{#if isPercent}}{{bench.p75}}%{{else}}{{#if isRatio}}{{bench.p75}}×{{else}}${{bench.p75}}{{/if}}{{/if}}
      </div>
      <div class="stat-sub">Upper quartile</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">25th Percentile</div>
      <div class="stat-value">
        {{#if isPercent}}{{bench.p25}}%{{else}}{{#if isRatio}}{{bench.p25}}×{{else}}${{bench.p25}}{{/if}}{{/if}}
      </div>
      <div class="stat-sub">Lower quartile</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Mean</div>
      <div class="stat-value">
        {{#if isPercent}}{{bench.mean_val}}%{{else}}{{#if isRatio}}{{bench.mean_val}}×{{else}}${{bench.mean_val}}{{/if}}{{/if}}
      </div>
      <div class="stat-sub">Population average</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Range</div>
      <div class="stat-value" style="font-size:18px;">{{bench.entity_count}} peers</div>
      <div class="stat-sub">Reporting this metric</div>
    </div>
    {{else}}
    <div class="stat-card"><div class="stat-label">No benchmark data available for this metric.</div></div>
    {{/if}}
  </div>

  {{!-- PEER DISTRIBUTION CHART --}}
  <div class="section-head"><h2>Peer Distribution</h2><span>Ranked · FY 2023</span></div>
  <div class="chart-panel" style="margin-bottom:20px;">
    <div class="panel-title">{{metricLabel}} — Ranked Peers <span>Top 12 shown</span></div>
    <canvas id="rankChart" style="max-height:280px;"></canvas>
  </div>

  {{!-- ENTITY TABLE --}}
  <div class="section-head"><h2>All Entities</h2><span>SIC {{sic}} · Ranked by {{metricLabel}}</span></div>
  <div class="peer-panel">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Organization</th>
          <th>Type</th>
          <th>{{metricLabel}}</th>
          <th>Revenue</th>
          <th>Net Income</th>
          <th>vs Median</th>
        </tr>
      </thead>
      <tbody>
        {{#each entities}}
        <tr>
          <td style="font-family:'Cormorant Garant',serif;font-size:18px;font-weight:600;color:var(--text-3);">{{inc @index}}</td>
          <td><a class="org-link" href="/org/{{id}}">{{name}}</a></td>
          <td><span class="badge-type {{typeBadgeClass type}}">{{type}}</span></td>
          <td><strong>{{metric_val}}</strong></td>
          <td style="color:var(--text-2);">{{revenue}}</td>
          <td style="color:var(--text-2);">{{net_income}}</td>
          <td>
            {{#if (gte metric_val ../median)}}
              <span style="font-size:11.5px;color:var(--pos);">↑ Above</span>
            {{else}}
              <span style="font-size:11.5px;color:var(--neg);">↓ Below</span>
            {{/if}}
          </td>
        </tr>
        {{else}}
        <tr><td colspan="7" style="text-align:center;padding:24px;color:var(--text-3);">No data available.</td></tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  // Refresh compare metrics in the global sectorApp() Alpine component
  const body = document.querySelector('body');
  if (body && body._x_dataStack) {
    const comp = body._x_dataStack[0];
    if (comp && typeof comp.initCompare === 'function') comp.initCompare();
  }

  const d    = JSON.parse(document.getElementById('sl-rank-chart').textContent);
  const dark = document.documentElement.getAttribute('data-theme') === 'dark';
  const grid = dark ? '#252525' : '#f0f0f0';
  const tick = dark ? '#666'    : '#8a8a8a';

  const rc = new Chart(document.getElementById('rankChart'), {
    type: 'bar',
    data: {
      labels: d.labels,
      datasets: [{ label: '{{metricLabel}}', data: d.values, backgroundColor: d.colors, borderRadius: 3 }],
    },
    options: {
      indexAxis: 'y', responsive: true, maintainAspectRatio: true,
      plugins: { legend: { display: false } },
      scales: {
        y: { ticks: { font: { family: 'DM Sans', size: 10.5 }, color: tick }, grid: { display: false } },
        x: { ticks: { font: { family: 'DM Sans', size: 10 },   color: tick }, grid: { color: grid } },
      },
    },
  });
  window.__slCharts.push(rc);
});
</script>
