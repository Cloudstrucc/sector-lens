{{!-- Sources modal — org-profile specific, opened via Sources button in topbar --}}
{{!-- "orgSources" array is injected by the org route and stored in window.__slSources --}}
<div class="modal-overlay" :class="{open: modal==='sources'}" @click.self="modal=null">
  <div class="modal" @click.stop style="max-width:560px;">
    <div class="modal-header">
      <div>
        <div class="modal-title">Data Sources</div>
        <div style="font-size:12px;color:var(--text-3);margin-top:2px;">
          Where this organization's financial data originates
        </div>
      </div>
      <button class="modal-close" @click="modal=null">×</button>
    </div>
    <div class="modal-body" style="padding-bottom:8px;">

      <template x-if="sources.length === 0">
        <p style="font-size:13px;color:var(--text-3);">No source information available for this organization.</p>
      </template>

      <template x-for="(src, i) in sources" :key="i">
        <div style="padding:14px 0;border-bottom:1px solid var(--border);">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:5px;">
            <span x-text="src.name"
                  style="font-size:14px;font-weight:500;color:var(--text);"></span>
            <span x-text="src.badge"
                  :style="`font-size:10px;padding:2px 7px;border-radius:2px;letter-spacing:.5px;
                    background:${src.badge==='Primary'?'#2563eb15':src.badge==='Manual'?'#d9770615':'#0a0a0a10'};
                    color:${src.badge==='Primary'?'#2563eb':src.badge==='Manual'?'#d97706':'var(--text-3)'};
                    border:1px solid ${src.badge==='Primary'?'#2563eb30':src.badge==='Manual'?'#d9770630':'var(--border)'}`">
            </span>
          </div>
          <p x-text="src.description"
             style="font-size:13px;color:var(--text-2);margin-bottom:8px;line-height:1.5;"></p>
          <template x-if="src.url">
            <a :href="src.url" target="_blank" rel="noopener noreferrer"
               style="font-size:12px;color:#2563eb;text-decoration:none;display:inline-flex;align-items:center;gap:4px;">
              <span x-text="src.url.replace(/^https?:\/\//, '').substring(0, 60) + (src.url.length > 70 ? '…' : '')"></span>
              <span style="font-size:10px;">↗</span>
            </a>
          </template>
          <template x-if="!src.url">
            <span style="font-size:12px;color:var(--text-3);font-style:italic;">Internal calculation</span>
          </template>
        </div>
      </template>

      <div style="padding-top:16px;font-size:11.5px;color:var(--text-3);line-height:1.6;">
        Data is ingested from public sources and may be subject to reporting lags.
        Always verify against official filings before making credit decisions.
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-primary btn-sm" @click="modal=null">Close</button>
    </div>
  </div>
</div>
